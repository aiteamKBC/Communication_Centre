# Optional: use a separate login database locally if needed.
# Leave unset if your local environment does not need the secondary login DB.
login_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/LOCAL_LOGIN_DB_NAME?sslmode=require

# Local frontend/backend callback URLs.
MS_REDIRECT_URI=http://127.0.0.1:8000/api/auth/microsoft/callback/
MS_FRONTEND_LOGIN_URL=http://localhost:3000/login
MS_FRONTEND_POPUP_URL=http://localhost:3000/login/microsoft-popup
